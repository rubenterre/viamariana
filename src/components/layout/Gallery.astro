---

<h2 class="main__h2">GALERÍA</h2>
<div class="galery">
  {religiousImages.map((item) => (
    <ImageGallery image={"img/religioso/"+item?.file} text={item?.text} alt={item?.alt} />
  ))}
</div>

<style>
  .galery {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
  }
  .main__h2 {
    font-family: var(--font-secondary);
    font-size: 3rem;
    margin-top: 3rem;
    text-align: center;
    color: var(--color-primary);
  }
</style>
