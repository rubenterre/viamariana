---
import ButtonContacto from "../ui/ButtonContacto.astro"
---

<header class="header__all">
  <a href="/"><img src="/img/LogoViaMariana.png" alt="Logo Via Mariana" class="logo__img" /></a>

  <nav class="header__navbar">
    <a href="#placeholder" class="navbar__a">Vía Mariana</a>
    <a href="/la-ruta" class="navbar__a">La ruta</a>
    <a href="/patrimonio" class="navbar__a">Patrimonio</a>
    <a href="/el-proyecto" class="navbar__a">El proyecto</a>
  </nav>
  <ButtonContacto />
</header>

<style>

  .logo__img {
    max-width: 165px;
  }

  .header__all {
    display: flex;
    justify-content: space-between;
    overflow: hidden;
    align-items: center;
    border-radius: 999px;
    height: 120px;
    background-color: var(--light)
    padding: 0 30px;
  }

  .header__navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 640px;
  }

  .navbar__a {
    text-decoration: none;
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 500;
    line-height: 26px;
  }
</style>
