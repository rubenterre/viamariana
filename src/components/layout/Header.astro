---
import ButtonContacto from "../ui/ButtonContacto.astro"
---

<header class="header__all">
  <a href="/">
    <img src="/img/LogoViaMariana.png" alt="Logo Via Mariana" class="logo__img">
  </a>
  <button class="burger" id="burger" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav class="header__navbar" id="navbar">
    <a href="/via-mariana" class="navbar__a">Vía Mariana</a>
    <a href="/la-ruta" class="navbar__a">La ruta</a>
    <a href="/patrimonio" class="navbar__a">Patrimonio</a>
    <a href="/el-proyecto" class="navbar__a">El proyecto</a>
    <div class="navbar__contact">
      <ButtonContacto />
    </div>
  </nav>
  <div class="header__contact">
    <ButtonContacto />
  </div>
</header>

<style>
  .logo__img {
    max-width: 165px;
  }

  .header__all {
    padding: 0 30px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    border-radius: 999px;
    background-color: var(--light);
    position: relative;
  }

  .header__navbar {
    width: 640px;
    display: flex;
    justify-content: space-around;
    align-items: center;
  }

  .navbar__a {
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 500;
    text-decoration: none;
  }

  .navbar__contact {
    display: none;
  }

  .header__contact {
    display: block;
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .burger span {
    width: 28px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 3px;
  }

  @media (max-width: 768px) {
    .burger {
      display: flex;
    }

    .header__contact {
      display: none;
    }

    .header__navbar {
      position: absolute;
      top: 120px;
      left: 0;
      width: 100%;
      flex-direction: column;
      background: var(--light);
      padding: 25px 0;
      gap: 20px;
      display: none;
    }

    .header__navbar.active {
      display: flex;
    }

    .navbar__contact {
      display: block;
      margin-top: 10px;
    }
  }
</style>

<script>
  const burger = document.querySelector("#burger");
  const navbar = document.querySelector("#navbar");

  burger?.addEventListener("click", () => {
    navbar?.classList.toggle("active");
  });
</script>
