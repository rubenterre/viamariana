---
import ButtonContacto from "../ui/ButtonContacto.astro"
---

<header class="header__all">
  <a href="/">
    <img src="/img/LogoViaMariana.png" alt="Logo Via Mariana" class="logo__img">
  </a>
  <nav class="header__navbar">
    <a href="/via-mariana" class="navbar__a">Vía Mariana</a>
    <a href="/la-ruta" class="navbar__a">La ruta</a>
    <a href="/patrimonio" class="navbar__a">Patrimonio</a>
    <a href="/el-proyecto" class="navbar__a">El proyecto</a>
  </nav>
  <ButtonContacto/>
</header>

<style>
  .logo__img {
    max-width: 165px;
  }

  .header__all {
    padding: 0 30px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    overflow: hidden;
    border-radius: 999px;
    background-color: var(--light)
  }

  .header__navbar {
    width: 640px;
    display: flex;
    justify-content: space-around;
    align-items: center;
  }

  .navbar__a {
    color: var(--color-primary);
    font-family: var(--font-secondary);
    font-size: 20px;
    font-weight: 500;
    text-decoration: none;
    line-height: 26px;
  }

