<section>
  <h2 class="h2">ENTES COLABORADORES</h2>
  <div class="img-1">
    <img class="img-1-1" src="./img/colaboradores/Logo_GDR_TierraAgua.png" alt="GDR tierra y agua">
    <img class="img-1-1" src="./img/colaboradores/Logo_GaliciaSuroeste.png" alt="Galicia suroeste">
    <img class="img-1-1-1" src="./img/colaboradores/Logo_GDR_PontevedraMorrazo.png" alt="GDR Pontevedra Monrazo">
    <img class="img-1-1-1" src="./img/colaboradores/Logo_Deloa.png" alt="Deloa">
    <img class="img-1-1" src="./img/colaboradores/Logo_GDR_CostaMorte.png" alt="GDR Costa da morte">
  </div>
  <div class="img-2">
    <img class="img-2-1" src="./img/colaboradores/Logo_TierrasCompostela.png" alt="Tierras de compostela">
    <img class="img-2-1" src="./img/colaboradores/Logo_XuntaGalicia.png" alt="Xunta_Galicia">
    <img class="img-2-1" src="./img/colaboradores/Logo_FinanciacionEuropea.png" alt="Union_Europea">
    <img class="img-2-1" src="./img/colaboradores/Logo_MinisterioAgricultura.png" alt="Gobierno de españa">
  </div>
</section>

<style>
  .h2 {
    margin-top: 5%;
    margin-bottom: 5%;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 21px;
    font-family: var(--font-secondary);
  }

  .imagenes {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 100px;
  }

  .img-1 {
    margin-bottom: 25px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
  }

  .img-1-1 {
    width: 200px;
  }

  .img-1-1-1 {
    width: 150px;
  }

  .img-2 {
    margin-bottom: 25px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-around;
  }

  .img-2-1 {
    width: 250px;
  }

  @media (max-width: 480px) {
    .img-1-1 {
      width: 50px;
    }

    .img-2 {
      padding-top: 10px;
    }

    .img-2-1 {
      width: 100px;
    }
  }

  @media (max-width: 424px) {
    .img-1 {
      flex-direction: column;
    }

    .img-1-1 {
      padding-bottom: 15px;
    }

    .img-2 {
      flex-direction: column;
    }

    .img-2-1 {
      padding-bottom: 15px;
    }
  }
</style>
