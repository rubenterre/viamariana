<section>
    <h2 class="h2">Entes colaboradores</h2>
    <div class="img-1">
        <img class="img-1-1" src="./img/colaboradores/GDR_tierra_y_agua.png" alt="GDR tierra y agua">
        <img class="img-1-1" src="./img/colaboradores/Galicia_suroeste.png" alt="Galicia suroeste">
        <img class="img-1-1" src="./img/colaboradores/GDR_Pontevedra_Monrazo.png" alt="GDR Pontevedra Monrazo">
        <img class="img-1-1" src="./img/colaboradores/Deloa.png" alt="Deloa">
        <img class="img-1-1" src="./img/colaboradores/GDR_Costa_da_morte.png" alt="GDR Costa da morte">
    </div>
    <div class="img-2">
        <img class="img-2-1" src="./img/colaboradores/Tierras_de_compostela.png" alt="Tierras de compostela">
        <img class="img-2-1" src="./img/colaboradores/Xunta.png" alt="Xunta">
        <img class="img-2-1" src="./img/colaboradores/Union_Europea.png" alt="Union_Europea">
        <img class="img-2-1" src="./img/colaboradores/Gobierno_de_españa.png" alt="Gobierno de españa">
    </div>
</section>

<style>
    .h2 {
        margin-top: 10%;
        margin-bottom: 5%;
        font-family: var(--font-primary);
        color: var(--color-primary);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .imagenes {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 100px;
    }

    .img-1 {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-evenly;
    }

    .img-1-1 {
        width: 100px;
    }

    .img-2 {
        padding-top: 50px;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-evenly;
    }

    .img-2-1 {
        padding-bottom: 25px;
        width: 200px;
    }

    @media (max-width: 768px) {
        .img-1-1 {
            width: 75px;
        }

        .img-2-1 {
            width: 150px;
        }
    }

    @media (max-width: 480px) {
        .img-1-1 {
            width: 50px;
        }
        .img-2 {
            padding-top: 10px;
        }

        .img-2-1 {
            width: 100px;
        }
    }

    @media (max-width: 424px) {
        .img-1 {
            flex-direction: column;
        }

        .img-1-1 {
            padding-bottom: 15px;
        }

        .img-2 {
            flex-direction: column;
        }

        .img-2-1 {
            padding-bottom: 15px;
        }
    }
</style>
