---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/layout/Footer.astro"
import Colaboradores from "../components/layout/Colaboradores.astro"
import HomeHero from "../components/layout/HomeHero.astro"
---
<Layout>
    <HomeHero/>

    <div class="row">
        <div class="col col--text">
            <h2 class="main__h2">Etapas</h2>
            <p class="etapas__p">Lorem ipsum dolor sit, amet consectetur adipisicing elit. Sequi reiciendis voluptate nemo ducimus deleniti tempora facilis exercitationem iusto? Voluptatem deleniti, tenetur commodi corrupti iure eligendi consectetur veniam. Aspernatur alias necessitatibus illum quia id explicabo assumenda accusamus sint, deserunt aliquid, quam quo? Adipisci cupiditate dolor impedit alias sunt facilis maiores modi?</p>
        </div>
        <div class="col col--img">
            <img src="img/mapa_2.png" alt="image" class="etapas__img">
        </div>
    </div>

    <h2 class="main__h2">Galería</h2>
    <div class="galery">
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
        <div class="galery__img">
            <img class="img--galery" src="img/image.png" alt="image">
        </div>
    </div>

    <Colaboradores/>
    <Footer />
</Layout>


<style>

    .main__h2{
        text-align: center;
        font-size: xx-large;
    }
    .row{
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
    }
    .col{
        width: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .col--text{
        padding: 0 80px;
    }
    .col--img{
        filter: drop-shadow(10px 8px 8px rgba(0, 0, 0, 0.25));
    }

    .galery{
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
    }
    .img--galery{
        width: 100%;
        border-radius: 20px;
    }
    .galery__img{
        width: 25%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px;
        transition: 1s ease-out;
    }
    .galery__img:hover{
        transform:scale(1.4);
    }

    @media (max-width:768px) {
        .row{
            flex-direction: column;
        }
        .col{
            width: 100%;
        }
        .col--text{
            padding: 50px 0;
        }
        .etapas__img{
            width: 70%;
        }
        
    }

</style>