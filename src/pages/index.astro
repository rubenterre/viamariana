---
import HomeHero from "../components/layout/HomeHero.astro";
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Colaboradores from "../components/layout/Colaboradores.astro";
import PopUp from "../components/layout/PopUp.astro";
import Gallery from "../components/layout/Gallery.astro";
import Testimonio from "../components/layout/Testimonio.astro";
---

<Layout>
    <Header />
    <HomeHero />
    <div class="row">
        <div class="col">
            <h2>Etapas</h2>
            <p class="etapas__p">
                Lorem ipsum dolor sit, amet consectetur adipisicing elit. Sequi
                reiciendis voluptate nemo ducimus deleniti tempora facilis
                exercitationem iusto? Voluptatem deleniti, tenetur commodi
                corrupti iure eligendi consectetur veniam. Aspernatur alias
                necessitatibus illum quia id explicabo assumenda accusamus sint,
                deserunt aliquid, quam quo? Adipisci cupiditate dolor impedit
                alias sunt facilis maiores modi?
            </p>
        </div>
        <div class="col col--img">
            <img src="img/mapa_2.png" alt="image" class="etapas__img">
        </div>
    </div>
    
    
    <Gallery />
    <Testimonio />
    <Colaboradores />
    <Footer />
</Layout>

<style>
    .row {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
    }

    .col {
        width: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .col--text {
        padding: 0 80px;
    }

    .col--img {
        filter: drop-shadow(10px 8px 8px rgba(0, 0, 0, 0.25));
    }





    @media (max-width: 768px) {
        .row {
            flex-direction: column;
        }

        .col {
            width: 100%;
        }

        .etapas__img {
            width: 70%;
        }
    }
</style>
