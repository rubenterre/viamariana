---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import HeroSections from "../components/layout/HeroSections.astro";
import Footer from "../components/layout/HeroSections.astro";
---

<Layout>
  <Header />
  <HeroSections title="Contacto" />
  <main class="contact-page">
    <div class="contact-page__container">
      <h1 class="contact-page__title">Contacto</h1>
      <div class="contact-page__grid">
        <aside class="info-card">
          <h2 class="info-card__title">Información</h2>
          <div class="info-card__item">
            <div class="info-card__content">
              <p class="info-card__label">WhatsApp</p>
              <p class="info-card__value">*Lorem, ipsum 123</p>
            </div>
          </div>
          <div class="info-card__item">
            <div class="info-card__content">
              <p class="info-card__label">Email</p>
              <p class="info-card__value">viamarianalusogalaica@gmail.com</p>
            </div>
          </div>
          <div class="info-card__social">
            <p class="info-card__label">Redes</p>
            <div class="info-card__links">
              <a href="https://www.facebook.com/viamarianalusogalaica/?locale=es_ES" class="info-card__link" >
                <img class="info-card__icon" src="./img/facebook.svg" alt="Icono facebook" />
              </a>
              <a href="https://www.instagram.com/viamarianalusogalaica/?hl=es" class="info-card__link" >
                <img class="info-card__icon" src="./img/instagram.svg" alt="Icono Instagram" />
              </a>
            </div>
          </div>
        </aside>
        <section class="form-card">
          <h2 class="form-card__title">Escríbenos</h2>
          <form class="form-card__form">
            <input class="form-card__input" type="text" placeholder="Nombre" required />
            <input class="form-card__input" type="email" placeholder="Email" required />
            <input class="form-card__input" type="text" placeholder="Asunto" />
            <textarea class="form-card__textarea" placeholder="Mensaje" rows="4" required></textarea>
            <button class="form-card__button" type="submit">Enviar</button>
          </form>
        </section>
      </div>
    </div>
  </main>
  <Footer/>
</Layout>

<style>
  .contact-page {
    padding: 3rem 0;
    background: var(--color-tertiary);
    min-height: calc(100vh - 200px);
  }

  .contact-page__container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .contact-page__title {
    color: var(--color-primary);
    font-size: 2.2rem;
    margin-bottom: 2rem;
    text-align: center;
    font-family: var(--font-secondary);
    font-weight: normal;
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .info-card {
    background: var(--light);
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .info-card__title {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
    font-family: var(--font-secondary);
  }

  .info-card__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .info-card__icon {
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }

  .info-card__content {
    display: flex;
    flex-direction: column;
  }

  .info-card__label {
    color: var(--color-primary);
    font-size: 1.2rem;
    font-family: var(--font-secondary);
    margin-bottom: 0.2rem;
  }

  .info-card__value {
    color: var(--dark);
    font-size: 1rem;
    font-family: var(--font-primary);
  }

  .info-card__social {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--grey);
  }

  .info-card__links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .info-card__link {
    padding: 0.4rem 0.8rem;
    background: var(--color-tertiary);
    color: var(--color-primary);
    text-decoration: none;
    border-radius: 24px;
    font-size: 1.2rem;
    font-family: var(--font-primary);
  }

  .info-card__link:hover {
    background: var(--color-primary);
  }

  .form-card {
    background: var(--light);
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .form-card__title {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-size: 1.3rem;
    font-family: var(--font-secondary);
  }

  .form-card__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-card__input,
  .form-card__textarea {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 24px;
    font-family: var(--font-primary);
    font-size: 1.2rem;
  }

  .form-card__input:focus,
  .form-card__textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .form-card__textarea {
    resize: vertical;
  }

  .form-card__button {
    background: var(--color-primary);
    color: var(--light);
    padding: 1rem;
    border: none;
    border-radius: 24px;
    font-size: 1.2rem;
    cursor: pointer;
    font-family: var(--font-secondary);
    margin-top: 0.5rem;
  }
</style>
