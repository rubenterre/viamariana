</Layout>

<style>

    .main{
  display: flex;
  justify-content: center;
  flex-direction: column;

}

.main__div{
  margin-top: 1rem;
  margin: 2rem;
}

.second__title{
  font-family: var(--font-primary);
  color: var(--color-primary);
  margin-top: 2rem;
}

.text{
  font-family: var(--font-primary);
  margin-top: 1.5rem;
  color: var(--grey);
}


.rutas{
  background-color: var(--color-primary);
  color: var(--color-tertiary);
  padding: 0.5rem;
}

.section__two{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.etapas{
  font-family: var(--font-primary);
  color: var(--color-primary);
  margin-top: 3rem;
  margin: 2rem;
  
}



/* Botones */

.botones{
  display: flex;
  justify-content: center;
 align-items: center;
  gap: 1.5rem;
  margin-bottom: 3rem;
  margin-top: 1rem;

}

.arrow{
  transform: scaleX(-1);
}

/* Enlaces PDF */

.text__h3{
  display: flex;
  justify-content: center;
  margin-bottom: 2rem;
  font-family: var(--font-primary);
  font-size: 20px;
  color: var(--color-primary);
  gap: 0.8rem;
  
}

.img__pdf{
  width: 30px;
}

.div__etapas{
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 2rem;
  
}


.div__a{
  display: flex;
  align-items: center;
  text-decoration: none;
  background: var(--color-primary);
  color: var(--color-tertiary);
  font-family: var(--font-primary);
  justify-content: center;
  border-radius: 100px;
  width: 48px;
  height: 48px;
  font-size: 18px;
}

.div__a:hover{
 background-color: var(--color-secondary);
 color: var(--color-primary);
 font-weight: 600;
}



/* Media queries */
 @media (max-width: 480px) {
  
 }

.main{
  display: flex;
  justify-content: center;
  flex-direction: column;
  padding: 1rem;
}

.main__div{
  margin: 1rem;
  text-align: center;
}

.second__tittle{
  margin-top: 1.5rem;
  font-size: 1.6rem;
}

.text{
  margin-top: 1rem;
  color: var(--grey);
  font-size: 0.95rem;
}

.section__two{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.etapas{
  margin: 1.5rem;
  text-align: center;
}

.mapa iframe{
  max-width: 100%;
  height: 500px;
  
}

.contador{
  font-family: var(--font-primary);
  font-size: 18px;
  font-weight: 600;
}

.mapa{
  border: solid 2px rgb(0, 0, 0);
}

.botones{
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}

.arrow{
  --direccion: -1;
  transform: scaleX(var(--direccion));
  width: 35px;
  transition: transform 0.3s ease;
}

.arrow:hover{
  transform: scaleX(var(--direccion)) scale(1.2);
}

.arrow--next{
  --direccion: 1;
  transform: scaleX(var(--direccion));
  width: 35px;
  transition: transform 0.3s ease;
}

.arrow--next:hover{
  transform: scaleX(var(--direccion)) scale(1.2);
  
}



 .text__h3{
  display: flex;
  justify-content: center;
  margin-bottom: 1.5rem;
  font-family: var(--font-primary);
  font-size: 18px;
  color: var(--color-primary);
  text-align: center;
}

.div__etapas{
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.div__a{
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  background: var(--color-primary);
  color: var(--color-tertiary);
  font-family: var(--font-primary);
  border-radius: 100px;
  width: 40px;
  height: 40px;
  font-size: 16px;
}


@media (min-width: 768px){

.main__div{
  max-width: 700px;
  margin: auto;
}

.second__tittle{
  font-size: 2rem;
}

.text{
  font-size: 1.1rem;
}

.mapa iframe{
  width: 750px;
  height: 420px;
}

.arrow,
.arrow--next{
  width: 45px;
}

}

.text__h3{
    font-size: 22px;
    margin-bottom: 2rem;
  }

  .div__etapas{
    gap: 1.5rem;
  }

  .div__a{
    width: 48px;
    height: 48px;
    font-size: 18px;
  }



@media (min-width: 1920px){

.main{
  max-width: 1400px;
  margin: auto;
}

.main__div{
  max-width: 900px;
}

.second__tittle{
  font-size: 2.5rem;
}

.text{
  font-size: 1.25rem;
}

.mapa iframe{
  width: 1000px;
  height: 550px;
}

.botones{
  gap: 2rem;
}

.arrow,
.arrow--next{
  width: 55px;
}
 .text__h3{
    font-size: 28px;
  }

  .div__etapas{
    gap: 2rem;
  }

  .div__a{
    width: 60px;
    height: 60px;
    font-size: 22px;
  }

}

</style>

<script>
    const rutas = {
        "0": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252719171&elevation=off&images=off&maptype=H",
        "1": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252941955&elevation=off&images=off&maptype=H",
        "2": "https://es.wikiloc.com/wikiloc/embedv2.do?id=253051127&elevation=off&images=off&maptype=H",
        "3": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252941078&elevation=off&images=off&maptype=H",
        "4": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252827474&elevation=off&images=off&maptype=H",
        "5": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252730617&elevation=off&images=off&maptype=H",
        "6": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252940609&elevation=off&images=off&maptype=H",
        "7": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252827878&elevation=off&images=off&maptype=H",
        "8": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252847567&elevation=off&images=off&maptype=H",
        "9": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252941458&elevation=off&images=off&maptype=H",
        "10": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252836166&elevation=off&images=off&maptype=H",
        "11": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252835799&elevation=off&images=off&maptype=H",
        "12": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252828322&elevation=off&images=off&maptype=H",
        "13": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252739322&elevation=off&images=off&maptype=H",
        "14": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252829209&elevation=off&images=off&maptype=H",
        "15": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252848987&elevation=off&images=off&maptype=H",
        "16": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252848215&elevation=off&images=off&maptype=H",
        "17": "https://es.wikiloc.com/wikiloc/embedv2.do?id=252820716&elevation=off&images=off&maptype=H"
    };

    const mapElement = document.getElementById("map");
    const contadorElement = document.getElementById("contador"); // El elemento que muestra el número
    const next = document.getElementById("next");
    const prev = document.getElementById("prev");
    let index = 0;

    // Función que actualiza el iframe y el número visual
    const updateRoute = (idx) => {
        mapElement.setAttribute("src", rutas[idx]);
        if (contadorElement) {
            // Mostramos idx + 1 para que el usuario vea "1" en vez de "0"
            contadorElement.textContent = idx + 0;
        }
    };

    // Inicializar
    updateRoute(index);

    next.addEventListener("click", () => {
        index++;
        if (index >= 18) {
            index = 0; // Reinicia al primero
        }
        updateRoute(index);
    });

    prev.addEventListener("click", () => {
        index--;
        if (index < 0) {
            index = 17; // Salta al último
        }
        updateRoute(index);
    });
</script>