};

const srcMap = document.getElementById("map").getAttribute("src");
const changeSrcMap = (src)=>{
    document.getElementById("map").setAttribute("src", src);
}
const buttons = document.querySelectorAll(".rutas");
const next = document.getElementById("next");
const prev = document.getElementById("prev");
let index = 0;
changeSrcMap(rutas[index]);


  next.addEventListener("click", () => {
      index++;
      if (index >= 18) {
          index = 0;
      }
      changeSrcMap(rutas[index]);
      console.log(index);
  });



  prev.addEventListener("click", () => {
      index--;
      if (index <= -1) {
          index = 17;
      }
      changeSrcMap(rutas[index]);
  });

</script>