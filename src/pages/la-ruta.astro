    <div class="mapa">
        <iframe
        id="map"
        
        src="https://es.wikiloc.com/wikiloc/embedv2.do?id=140385452&elevation=off&images=off&maptype=H"
        width="850"
        height="500"
        ></iframe>
        <div style="color: #00378f; font-size: 11px; line-height: 16px">
            Powered by&nbsp;<a
            style="color: #4c8c2b; font-size: 11px; line-height: 16px"
            target="_blank"
            href="https://es.wikiloc.com"
            >Wikiloc</a
            >
        </div>
    </div>
    <div class="botones">
        <!-- <button id="prev"> -->
