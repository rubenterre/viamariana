---
import Layout from "../layouts/Layout.astro"
import flecha from "../assets/logo_arrow_viamariana.svg"
import { Image } from 'astro:assets'
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import HeroSections from "../components/layout/HeroSections.astro"
---
<Layout>
  <Header/>
  <HeroSections title="La Ruta"/>
    <main class="main">

    <section class="section">
       <div class="main__div">
        
        <h2 class="second__title">Trazado completo</h2>
        <h3 class="text">La Vía Mariana recorre más de 350km desde Braga (Portugal) hasta Muxía (Galicia), atravesando 6 GDR gallegos y múltiples ayuntamientos. Su trazado conecta santuarios marianos, espacios naturales, aldeas y villas, configurando una ruta de gran riqueza paisajística y cultural.</h3>
       </div>
      </section>

      <section class="section__two">
        <h2 class="etapas">Etapas</h2>
        <!-- 
            <div class="controles">
            <div class="slider">
        <div class="slide active">Slide 1</div>
        <div class="slide">Slide 2</div>
        <div class="slide">Slide 3</div> -->
    
   
         <!-- <div class="buttons">
      <button id="00" class="rutas">00</button>
      <button id="01" class="rutas">01</button>
      <button id="02" class="rutas">02</button>
      <button id="03" class="rutas">03</button>
      <button id="04" class="rutas">04</button>
      <button id="05" class="rutas">05</button>
      <button id="06" class="rutas">06</button>
      <button id="07" class="rutas">07</button>
      <button id="08" class="rutas">08</button>
      <button id="09-10" class="rutas">09-10</button>
      <button id="11" class="rutas">11</button>
      <button id="12" class="rutas">12</button>
      <button id="13" class="rutas">13</button>
      <button id="14" class="rutas">14</button>
      <button id="15" class="rutas">15</button>
      <button id="16" class="rutas">16</button>
      <button id="17" class="rutas">17</button>
    </div> -->
    <div class="mapa">
        <iframe
        id="map"
        
        src="https://es.wikiloc.com/wikiloc/embedv2.do?id=140385452&elevation=off&images=off&maptype=H"
        width="850"
        height="500"
        ></iframe>
        <div style="color: #777; font-size: 11px; line-height: 16px">
            Powered by&nbsp;<a
            style="color: #4c8c2b; font-size: 11px; line-height: 16px"
            target="_blank"
            href="https://es.wikiloc.com"
            >Wikiloc</a
            >
        </div>
    </div>
    <div class="botones">
        <!-- <button id="prev"> -->
            <img class="arrow" id="prev" src={flecha.src} alt="flecha">
        <!-- </button> -->
        <!-- <button id="next"> -->
            <img class="arrow--next" id="next" src={flecha.src} alt="flecha">
        <!-- </button> -->
    </div>
      </section>

    </main>
   <Footer/>
</Layout>

<style>

    .main{
  display: flex;
  justify-content: center;
  flex-direction: column;

}

.main__div{
  margin-top: 1rem;
  margin: 2rem;
}

.second__title{
  font-family: var(--font-primary);
  margin-top: 2rem;
}

.text{
  font-family: var(--font-primary);
  margin-top: 1.5rem;
  color: var(--grey);
}


.rutas{
  background-color: var(--color-primary);
  color: var(--color-tertiary);
  padding: 0.5rem;
}

.section__two{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
.etapas{
  font-family: var(--font-primary);
  margin-top: 3rem;
  margin: 2rem;
}



/* Botones */

.botones{
  display: flex;
  justify-content: center;
 align-items: center;
  gap: 1.5rem;
  margin-bottom: 3rem;
  margin-top: 1rem;

}

.arrow{
  transform: scaleX(-1);
}


/* Media queries */
 @media (max-width: 480px) {
  
 }

.main{
  display: flex;
  justify-content: center;
  flex-direction: column;
  padding: 1rem;
}

.main__div{
  margin: 1rem;
  text-align: center;
}

.second__tittle{
  margin-top: 1.5rem;
  font-size: 1.6rem;
}

.text{
  margin-top: 1rem;
  color: var(--grey);
  font-size: 0.95rem;
}

.section__two{
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.etapas{
  margin: 1.5rem;
  text-align: center;
}

.mapa iframe{
  max-width: 100%;
  height: 500px;
  
}

.botones{
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}

.arrow{
  transform: scaleX(-1);
  width: 35px;
}

.arrow--next{
  width: 35px;
}


@media (min-width: 768px){

.main__div{
  max-width: 700px;
  margin: auto;
}

.second__tittle{
  font-size: 2rem;
}

.text{
  font-size: 1.1rem;
}

.mapa iframe{
  width: 750px;
  height: 420px;
}

.arrow,
.arrow--next{
  width: 45px;
}

}


@media (min-width: 1920px){

.main{
  max-width: 1400px;
  margin: auto;
}

.main__div{
  max-width: 900px;
}

.second__tittle{
  font-size: 2.5rem;
}

.text{
  font-size: 1.25rem;
}

.mapa iframe{
  width: 1000px;
  height: 550px;
}

.botones{
  gap: 2rem;
}

.arrow,
.arrow--next{
  width: 55px;
}

}

</style>

<script>
    const rutas = {
