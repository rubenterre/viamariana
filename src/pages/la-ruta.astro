    let index = 0;

    // Función que actualiza el iframe y el número visual
    const updateRoute = (idx) => {
        mapElement.setAttribute("src", rutas[idx]);
        if (contadorElement) {
            // Mostramos idx + 1 para que el usuario vea "1" en vez de "0"
            contadorElement.textContent = idx + 0;
        }
    };

    // Inicializar
    updateRoute(index);

    next.addEventListener("click", () => {
        index++;
        if (index >= 18) {
            index = 0; // Reinicia al primero
        }
        updateRoute(index);
    });

    prev.addEventListener("click", () => {
        index--;
        if (index < 0) {
            index = 17; // Salta al último
        }
        updateRoute(index);
    });
