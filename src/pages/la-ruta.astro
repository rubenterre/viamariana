---
import Layout from "../layouts/Layout.astro"
import flecha from "../assets/logo_arrow_viamariana.svg"
import { Image } from 'astro:assets'
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import HeroSections from "../components/layout/HeroSections.astro"
---
<Layout>
  <Header/>
  <HeroSections title="La Ruta"/>
    <main class="main">

    <section class="section">
      <h2 class="second__title">TRAZADO COMPLETO</h2>
       <div class="main__div">
        <h3 class="text">La Vía Mariana recorre más de 350km desde Braga (Portugal) hasta Muxía (Galicia), atravesando 6 GDR gallegos y múltiples ayuntamientos. Su trazado conecta santuarios marianos, espacios naturales, aldeas y villas, configurando una ruta de gran riqueza paisajística y cultural.</h3>
       <img class="img__rutas" src="public/img/ITINERARIO.png" alt="Itinerario de la ruta">
      </div>
      </section>

      <section class="section__two">
        <h2 class="etapas">ETAPAS</h2>
       
    <div class="mapa">
        <iframe
        id="map"
        
        src="https://es.wikiloc.com/wikiloc/embedv2.do?id=140385452&elevation=off&images=off&maptype=H"
        width="850"
        height="500"
        ></iframe>
        <div style="color: #00378f; font-size: 11px; line-height: 16px">
            Powered by&nbsp;<a
            style="color: #4c8c2b; font-size: 11px; line-height: 16px"
            target="_blank"
            href="https://es.wikiloc.com"
            >Wikiloc</a
            >
        </div>
    </div>
    <div class="botones">
        <!-- <button id="prev"> -->
            <img class="arrow" id="prev" src={flecha.src} alt="flecha">
        <!-- </button> -->
         <p class="contador" id="contador">0</p>
        <!-- <button id="next"> -->
            <img class="arrow--next" id="next" src={flecha.src} alt="flecha">
        <!-- </button> -->
    </div>
      </section>

      <div class="div__pdf">
      <h3 class="text__h3">
        <img class="pdf" src="public/img/img__pdf.avif" alt="Icono PDF">
         Descarga más información de tu ruta en PDF</h3>
         </div>

      <div class="div__etapas">
        <ul class="div__ul">
          <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-00.pdf" download="ruta__00" >0</a>
        <a href="public/archivos/VMLG-00.pdf" class="div_a--descripcion" download="ruta__00">Ruta VMLG-00</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-01.pdf" download="ruta__01">1</a>
        <a href="public/archivos/VMLG-01.pdf" class="div_a--descripcion" download="ruta__01">Ruta VMLG-01</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-02.pdf" download="ruta__02">2</a>
        <a href="public/archivos/VMLG-02.pdf" class="div_a--descripcion" download="ruta__02">Ruta VMLG-02</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-03.pdf" download="ruta__03">3</a>
        <a href="public/archivos/VMLG-03.pdf" class="div_a--descripcion" download="ruta__03">Ruta VMLG-03</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-04.pdf" download="ruta__04">4</a>
        <a href="public/archivos/VMLG-04.pdf" class="div_a--descripcion" download="ruta__04">Ruta VMLG-04</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-05.pdf" download="ruta__05">5</a>
        <a href="public/archivos/VMLG-05.pdf" class="div_a--descripcion" download="ruta__05">Ruta VMLG-05</a>
        </li>
        <li class="div__lista">
        <a class="div__a" href="public/archivos/VMLG-06.pdf" download="ruta__06">6</a>
        <a href="public/archivos/VMLG-06.pdf" class="div_a--descripcion" download="ruta__06">Ruta VMLG-06</a>
        </li>
        <li class="div__lista">
