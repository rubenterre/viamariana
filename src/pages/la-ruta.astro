---
import Layout from "../layouts/Layout.astro"
import flecha from "../assets/logo_arrow_viamariana.svg"
import { Image } from 'astro:assets'
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import HeroSections from "../components/layout/HeroSections.astro"
---
<Layout>
  <Header/>
  <HeroSections title="La Ruta"/>
    <main class="main">

    <section class="section">
       <div class="main__div">
        
        <h2 class="second__title">Trazado completo</h2>
        <h3 class="text">La Vía Mariana recorre más de 350km desde Braga (Portugal) hasta Muxía (Galicia), atravesando 6 GDR gallegos y múltiples ayuntamientos. Su trazado conecta santuarios marianos, espacios naturales, aldeas y villas, configurando una ruta de gran riqueza paisajística y cultural.</h3>
       </div>
      </section>

      <section class="section__two">
        <h2 class="etapas">Etapas</h2>
        <!-- 
            <div class="controles">
            <div class="slider">
        <div class="slide active">Slide 1</div>
        <div class="slide">Slide 2</div>
        <div class="slide">Slide 3</div> -->
    
   
