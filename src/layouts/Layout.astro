---
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width">
		<link rel="icon" href="/favicon.png">
		<meta name="generator" content={Astro.generator}>

		    <slot name="head">
      			<title>{title}</title>
    		</slot>
<!-- 		<title>Via Mariana - Ruta luso-galaica</title>
 -->		
		<meta name="description" content="Esta es la página de Via Mariana">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css" />

		<!-- Open Graph General (Facebook, LinkedIn, etc.) -->
<meta property="og:title" content="Título atractivo de tu página" />
<meta property="og:description" content="Breve descripción que invite a hacer clic (aprox. 155 caracteres)." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://www.tusitio.com" />
<meta property="og:image" content="https://www.tusitio.com" />
<meta property="og:site_name" content="Nombre de tu Marca o Sitio" />
<meta property="og:locale" content="es_ES" />

<!-- Etiquetas específicas para Twitter (X) -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Título para Twitter" />
<meta name="twitter:description" content="Descripción optimizada para Twitter." />
<meta name="twitter:image" content="https://www.tusitio.com" />

	</head>
	<body>
		<slot />
		
		 <script defer src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
		  <!-- <script client src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script> -->
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		outline: 0;
		box-sizing: border-box;
	}

	html {
		font-size: 14px;
		scroll-behavior: smooth;
	}

	@font-face {
		font-family: Poppins-Regular;
		src: url(./fonts/Poppins-Regular.ttf);
	}

	@font-face {
		font-family: Poppins-Medium;
		src: url(./fonts/Poppins-Medium.ttf);
	}

	@font-face {
		font-family: OpenSans;
		src: url(./fonts/OpenSans-VariableFont_wdth.ttf);
	}

	:root {
		--font-primary: Poppins-Regular;
		--font-secondary: Poppins-Medium;
		--font-tertiary: OpenSans;
		--color-primary: #00378f;
		--color-secondary: #efb91f;
		--color-tertiary: #f8f9fb;
		--grey: #7f7f7f;
		--light: #ffffff;
		--dark: #1a1a1a;
	}

	body {
		background: var(--light);
		color: var(--dark);
		-webkit-font-smoothing: antialiased;
	}

	body, input, button {
		font-family: var(--font-primary);
	}

	button {
		cursor: pointer;
	}
</style>
