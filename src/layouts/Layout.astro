---
import Organization from '../components/structured-data/Organization.astro';
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width">
		<link rel="icon" href="/favicon.png">
		<meta name="generator" content={Astro.generator}>
		<title>Via Mariana - Ruta luso-galaica</title>
		<slot name="head" />
		<slot name="meta"/>
	</head>
	<body>
		<slot />
		<Organization />
		<slot name="scripts" />
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		outline: 0;
		box-sizing: border-box;
	}

	/* Visually hidden class for screen reader only content */
	.visually-hidden {
		position: absolute !important;
		width: 1px; height: 1px;
		padding: 0; margin: -1px;
		overflow: hidden; clip: rect(0, 0, 0, 0);
		white-space: nowrap; /* added line */
		border: 0;
	}

	html {
		font-size: 14px;
		scroll-behavior: smooth;
	}

	@font-face {
		font-family: Poppins-Regular;
		src: url(./fonts/Poppins-Regular.ttf);
	}

	@font-face {
		font-family: Poppins-Medium;
		src: url(./fonts/Poppins-Medium.ttf);
	}

	@font-face {
		font-family: OpenSans;
		src: url(./fonts/OpenSans-VariableFont_wdth.ttf);
	}

	:root {
		--font-primary: Poppins-Regular;
		--font-secondary: Poppins-Medium;
		--font-tertiary: OpenSans;
		--color-primary: #003387;
		--color-secondary: #efb91f;
		--color-tertiary: #f8f9fb;
		--color-dark: #1a1a1a;
		--color-gray: #2b2b2b;
		--light: #ffffff;
	}

	body {
		background: var(--light);
		color: var(--dark);
		-webkit-font-smoothing: antialiased;
	}

	body, input, button {
		font-family: var(--font-primary);
	}

	button {
		cursor: pointer;
	}
</style>
